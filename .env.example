# ============================================================
# FUSION GYM PORTAL — Template de Variáveis de Ambiente
# NUNCA commite o arquivo .env real. Este arquivo (.env.example)
# é apenas um template seguro para orientar o setup.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=fusion_user

# SEGURANÇA: Substitua por uma senha forte e aleatória antes de qualquer deploy.
# Gere com: openssl rand -base64 32
POSTGRES_PASSWORD=SUBSTITUA_POR_SENHA_FORTE_ALEATORIA

POSTGRES_DB=fusion_portal

# URL completa de conexão com o banco (usada pelo Prisma)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://fusion_user:SUBSTITUA_POR_SENHA_FORTE_ALEATORIA@localhost:5432/fusion_portal

# ── JWT ──────────────────────────────────────────────────────
# SEGURANÇA: Obrigatório em produção. Mínimo 64 bytes hexadecimais.
# Não use palavras como 'secret', 'dev' ou 'test'.
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SUBSTITUA_POR_STRING_DE_64_BYTES_HEX

# ── CORS / Frontend ──────────────────────────────────────────
# SEGURANÇA: Obrigatório em produção. Defina o domínio exato do frontend.
# Exemplo: https://portal.seudominio.com.br
# Em desenvolvimento: http://localhost:5173
FRONTEND_URL=https://SUBSTITUA_PELO_DOMINIO_DO_FRONTEND

# ── Ambiente ─────────────────────────────────────────────────
# Deve ser 'production' em produção e 'development' em desenvolvimento.
NODE_ENV=production

# ── CPF (proteção futura) ────────────────────────────────────
# SEGURANÇA: Segredo separado para hash HMAC-SHA256 do CPF, caso seja persistido no banco.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CPF_HMAC_SECRET=SUBSTITUA_POR_STRING_DE_32_BYTES_HEX

# ── NextFit API ──────────────────────────────────────────────
NEXTFIT_API_URL=https://api.nextfit.com.br
NEXTFIT_API_TOKEN=

# ── Webhooks ─────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.fusion.satomiq.com/webhook/portal
