generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  firstName   String?
  lastName    String?
  phone       String?
  cpf         String?  @unique
  birthDate   DateTime?
  nextfit_id  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
